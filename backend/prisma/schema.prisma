generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 用户（Phase 2 实现，Phase 1 仅 seed 默认用户） ───

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgs       OrgMember[]
  workspaces Workspace[]

  @@map("users")
}

// ─── 组织（Phase 0 前原名 Workspace，现作为 User → Org → Workspace → Artifact 的最上层） ───

model Org {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    OrgMember[]
  workspaces Workspace[]

  @@map("orgs")
}

model OrgMember {
  id       String   @id @default(cuid())
  orgId    String
  userId   String
  role     String   @default("editor")
  joinedAt DateTime @default(now())

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

// ─── 工作空间（Phase 0 前原名 Document，现为实际承载 artifact 的容器） ───

model Workspace {
  id          String   @id @default(cuid())
  orgId       String
  createdById String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])
  tables    Table[]
  folders   Folder[]
  designs   Design[]

  @@index([orgId])
  @@map("workspaces")
}

// ─── 数据表（fields + views 作为 JSONB 存储） ───

model Table {
  id                 String   @id @default(cuid())
  workspaceId        String
  name               String
  parentId           String?
  order              Int      @default(0)
  fields             Json     @default("[]")
  views              Json     @default("[]")
  autoNumberCounters Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  records   Record[]

  @@index([workspaceId])
  @@index([parentId])
  @@map("tables")
}

// ─── 记录（独立表，通过 tableId 关联） ───

model Record {
  id         String   @id @default(cuid())
  tableId    String
  cells      Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  modifiedBy String?

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([cells(ops: JsonbPathOps)], type: Gin)
  @@map("records")
}

// ─── 文件夹（树形结构，自引用） ───

model Folder {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  parentId    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]  @relation("FolderTree")

  @@index([workspaceId])
  @@index([parentId])
  @@map("folders")
}

// ─── Chat Agent 对话 & 消息（持久化到 Postgres） ───
// 原 conversationStore 使用内存 Map，backend 重启即丢；迁到 Prisma 后跨进程持久。

model Conversation {
  id           String   @id @default(cuid())
  workspaceId  String
  title        String   @default("新对话")
  summary      String?
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages Message[]

  @@index([workspaceId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool"
  content        String
  thinking       String?
  toolCalls      Json?
  toolResult     Json?
  timestamp      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("messages")
}

// ─── 设计稿（Figma 链接） ───

model Design {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  parentId     String?
  order        Int      @default(0)
  figmaUrl     String?
  figmaFileKey String?
  figmaNodeId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([parentId])
  @@map("designs")
}
