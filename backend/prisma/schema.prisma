generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 用户（Phase 2 实现，Phase 1 仅 seed 默认用户） ───

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  /// Display handle — shown in breadcrumb, default workspace name, default
  /// chatbot name. **Not unique, not used for login** (email is the only
  /// login identifier). Users can change it freely and collisions are fine.
  username  String?
  name      String
  avatarUrl String?
  /// bcrypt hash of the password. Null means "never set a password yet"
  /// (legacy rows pre-auth — treated as "must reset" once auth lands).
  passwordHash String?
  /// Per-user UI preferences. Currently holds:
  ///   { theme?: "light"|"dark"|"system", locale?: "zh"|"en",
  ///     deleteProtection?: boolean }
  /// Empty {} means "fall back to browser localStorage / system default".
  /// 详见 docs/per-user-preferences.md。
  preferences Json @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgs         OrgMember[]
  workspaces   Workspace[]
  agents       Agent[]
  customModels CustomModel[]

  @@map("users")
}

// ─── CustomModel（用户自定义模型，per-user，跨 agent 共享） ───

model CustomModel {
  id              String   @id @default(cuid())
  userId          String
  modelId         String   // 用户定义的 model ID（如 "my-gpt4"）
  displayName     String
  provider        String   // "openai-compatible" | "anthropic" | "custom"
  baseUrl         String   // API base URL
  apiKey          String   // 加密存储的 API key
  providerModelId String   // 实际发给 provider 的 model name
  capabilities    Json     @default("{}")  // { thinking, toolUse, contextWindow }
  group           String   @default("custom")
  specialty       String?
  visible         Boolean  @default(true)
  available       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modelId])
  @@index([userId])
  @@map("custom_models")
}

// ─── Agent（属于用户，跨 Workspace 的长期 Agent 身份） ───
// 身份文件（soul.md / profile.md / config.json）落在文件系统
// ~/.imagebase/agents/<id>/ 下；DB 只保存元数据与关系。

model Agent {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Agent")
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([userId])
  @@map("agents")
}

// ─── 组织（Phase 0 前原名 Workspace，现作为 User → Org → Workspace → Artifact 的最上层） ───

model Org {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    OrgMember[]
  workspaces Workspace[]

  @@map("orgs")
}

model OrgMember {
  id       String   @id @default(cuid())
  orgId    String
  userId   String
  role     String   @default("editor")
  joinedAt DateTime @default(now())

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

// ─── 工作空间（Phase 0 前原名 Document，现为实际承载 artifact 的容器） ───

model Workspace {
  id          String   @id @default(cuid())
  orgId       String
  createdById String
  name        String
  description String?
  /// AI 生成的工作区一句话摘要（~50 字）。null 表示尚未生成；前端会
  /// 显示一个静态默认。每日 04:00 UTC+8 由 heartbeat 异步刷新（见
  /// services/workspaceSummaryService.ts）。
  aiSummary   String?
  /// AI 生成的 slogan / punchline（~20 字以内）。
  aiSlogan    String?
  /// 上次 AI 摘要生成时间。判断"今天是否已经生成过"用。
  aiSummaryAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])
  tables    Table[]
  folders   Folder[]
  designs   Design[]
  ideas     Idea[]
  demos     Demo[]

  @@index([orgId])
  @@map("workspaces")
}

// ─── Token 使用记录 —— 追踪每次 LLM 调用的 prompt/completion token 数 ───
// 写入触发：每个 provider adapter 完成一次 stream 后，调用
//   recordTokenUsage(userId, workspaceId, feature, ...)
// 用途：
//   1) 顶栏右栏 totalTokens 展示（workspace 累计）
//   2) 将来管理后台展示明细（按 feature / model / 时间范围）
//   3) 计费 / 配额（暂不开启）
model TokenUsage {
  id               String   @id @default(cuid())
  userId           String
  /// 部分调用没有具体 workspace 上下文（如登录后立刻发起的全局 prompt
  /// suggestion），允许 null。
  workspaceId      String?
  /// "ark" | "oneapi-anthropic" | "oneapi-openai"
  provider         String
  /// 后端 modelRegistry 里的 model id —— "doubao-2.0" / "claude-opus-4.7" 等
  model            String
  /// 调用场景标签 —— "chat" / "ai-filter" / "field-suggest" / "taste-meta"
  /// / "workspace-summary" / "prompt-suggest"
  feature          String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  /// 可选，便于后续根据响应延迟做监控
  durationMs       Int?
  createdAt        DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@map("token_usage")
}

// ─── 数据表（fields + views 作为 JSONB 存储） ───

model Table {
  id                 String   @id @default(cuid())
  workspaceId        String
  name               String
  parentId           String?
  order              Int      @default(0)
  fields             Json     @default("[]")
  views              Json     @default("[]")
  autoNumberCounters Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  records   Record[]

  @@index([workspaceId])
  @@index([parentId])
  @@map("tables")
}

// ─── 记录（独立表，通过 tableId 关联） ───

model Record {
  id         String   @id @default(cuid())
  tableId    String
  cells      Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  modifiedBy String?

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([cells(ops: JsonbPathOps)], type: Gin)
  @@map("records")
}

// ─── 文件夹（树形结构，自引用） ───

model Folder {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  parentId    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]  @relation("FolderTree")

  @@index([workspaceId])
  @@index([parentId])
  @@map("folders")
}

// ─── Chat Agent 对话 & 消息（持久化到 Postgres） ───
// 原 conversationStore 使用内存 Map，backend 重启即丢；迁到 Prisma 后跨进程持久。

model Conversation {
  id           String   @id @default(cuid())
  workspaceId  String
  agentId      String?
  title        String   @default("新对话")
  summary      String?
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // V3.0 multi-conversation:in-flight 状态供 UI 知道当前 conv 正在 generating
  // 还是 idle (重启时强制 reset 为 idle)
  status       String   @default("idle") // "idle" | "generating" | "synth"

  // PR9: 块级评论。可选 — 普通对话不填,挂在某 idea block 上的"评论对话"填:
  //   attachedToType="idea-block", attachedToId="<ideaId>#<blockId>"
  // 将来扩展到 attachedToType="taste"/"table-record" 等其他锚点。
  // FE 在 IdeaEditor 看 idea 时通过 GET /api/ideas/:id/comments 拉 attachedTo
  // 该 idea 任一 block 的对话,渲染 block 评论计数 / 跳转气泡。
  attachedToType String?
  attachedToId   String?

  agent    Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([workspaceId, updatedAt(sort: Desc)])
  @@index([agentId, updatedAt(sort: Desc)])
  // V3.0 PR1: createdAt desc list 排序索引
  @@index([workspaceId, createdAt(sort: Desc)])
  // PR9: 反查"某 block 上有哪些对话"
  @@index([attachedToType, attachedToId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant" | "tool"
  content        String
  thinking       String?
  toolCalls      Json?
  toolResult     Json?
  timestamp      DateTime @default(now())
  // V3.0 multi-conversation
  branchTag       String?  // "main" | "appended" | "synthesis" | null (legacy)
  parentMessageId String?  // synthesis 指向被合成主线 user message;branch 也可指向
  seq             Int      @default(0)  // per-conv 单调递增,前端按此排序

  // V3.0 UX: 把 GeneratingMeta 的最终值持久化,刷新页面后历史 assistant
  // 气泡仍能渲染 "Generated · X 秒 · Y tokens"。只在 turn 自然结束(done)
  // 时由 chatAgentService 写入,turn 跑到一半的中间态不写(避免脏数据)。
  // 三列都允许 null —— user message / 旧消息 / 中断的 turn 都没有 meta。
  durationMs       Int?
  promptTokens     Int?
  completionTokens Int?
  /// Model ID used for this turn (e.g. "claude-opus-4.7", "doubao-2.0").
  /// Only set on assistant messages at turn completion.
  modelId          String?
  /// Source context: active skill names or habit ID for this turn.
  /// Format: "skill:table-skill,analyst-skill" or "habit:habit_system_evolve" or null.
  source           String?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@index([conversationId, seq])
  @@map("messages")
}

/// PR3 Agent Workflow:Subagent 嵌套调用记录。每次 host 通过 spawn_subagent 工具
/// (或 PR4 workflow 的 subagent action 节点) 拉起子 agent loop,在这里建一行。
/// 子 agent 自己的消息不写 Message 表(否则污染主 conversation 历史)——它们
/// 沉到 toolCallsJson + finalText 里,host 的下一轮上下文只看到聚合后的
/// finalText。前端展开 SubagentBlock 时按需加载完整 toolCallsJson。
model SubagentRun {
  id                   String   @id @default(cuid())
  parentMessageId      String   // host 消息 id —— 标定这次 subagent 是哪一回合调起的
  parentConversationId String
  hostAgentId          String   // host agent (与父 conversation.agentId 同步)
  subagentModel        String   // 实际跑这次的模型 id (resolveModelForCall 后的)
  requestedModel       String   // 用户/host 指定的模型 id (可能 fallback 后不同)

  // 输入
  systemPrompt String  @db.Text
  userPrompt   String  @db.Text
  allowedTools String[] @default([]) // [] = 继承全部 (PR3 默认)
  maxRounds    Int     @default(10)

  // 嵌套
  parentSubagentRunId String? // depth>0 时指向父 subagent
  depth               Int     @default(0) // 0 = host 直接调,1 = subagent 调 subagent
  workflowNodeId      String? // PR4 workflow 节点 id,触发于 workflow 的 subagent action

  // 状态
  status        String  // "pending" | "running" | "success" | "error" | "aborted" | "danger-paused"
  finalText     String? @db.Text
  thinkingText  String? @db.Text
  toolCallsJson Json?   // 同 Message.toolCalls 结构,记录 subagent 自己用了什么工具
  errorMessage  String? @db.Text

  // 计量
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  durationMs       Int?
  promptTokens     Int?
  completionTokens Int?

  // V3.0 multi-conversation
  kind          String?  // "main" | "branch" | "synth" | "external" | null (legacy)
  branchId      String?  // turnOrchestrator 的 BranchState.branchId,关联 batch 内位置
  workflowRunId String?  // V3.0 PR5: append-batch 的 WorkflowRun id

  @@index([parentMessageId])
  @@index([parentConversationId, startedAt])
  @@index([branchId])
  @@index([parentSubagentRunId])
  @@map("subagent_runs")
}

/// V2.1 Agent Workflow:Workflow 执行记录持久化。每次 host 调用
/// `execute_workflow_template` 拉起一次 workflow 时建一行,timeline (节点
/// 起止 / 循环迭代 / 分支启动) 全部沉到 nodeEventsJson。subagent runs 通过
/// 各自的 `workflowNodeId` 关联回这里。
///
/// 历史回放:`getConversationMessages` 返回值 join `WorkflowRun` 表(按
/// parentMessageId)填到 message.workflowRuns,FE 重新渲染 WorkflowBlock 时
/// 间线和关联的 SubagentBlock。
model WorkflowRun {
  id                   String   @id @default(cuid())
  parentMessageId      String   // host 消息 id
  parentConversationId String
  hostAgentId          String
  templateId           String   // "review" | "brainstorm" | "cowork" | "concurrent-data" | (custom 时空)
  /// 启动参数 (e.g. {authorModel, reviewerModel, maxIterations} for review)
  paramsJson           Json?
  /// DSL doc 完整 JSON 快照 (回放时不需要再 build template)
  docJson              Json?
  /// Linear timeline: workflow_start / node_start / node_end / loop_iter / branch_start / end
  /// 与 FE UiWorkflowRun.nodeEvents 同结构
  nodeEventsJson       Json?

  status        String  // "running" | "success" | "error" | "aborted"
  errorMessage  String? @db.Text
  /// 取自 ctx.scope.summary.finalText / scope.draft.finalText 的简短结果
  finalSummary  String? @db.Text

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?

  @@index([parentMessageId])
  @@index([parentConversationId, startedAt])
  @@map("workflow_runs")
}

// ─── User-defined Skill (V2: fs-first, 2026-04-28) ─────────────────────────
// V2 改为 filesystem-first:source of truth 是 SKILL.md (YAML frontmatter +
// Markdown body) + workflows/*.json,放在 BlobStorage 下
//   agents/<ownerId>/skills/<id>/SKILL.md
//   agents/<ownerId>/skills/<id>/workflows/0.json
// DB 只保留薄索引(name 用于 list / 唯一性,enabled 用于过滤,invokedCount
// 用于使用统计)。description / triggers / promptFragment / workflowDocs /
// toolWhitelist / sourceConversationId / sourceWorkflowRunId 全部下沉到 fs。
// 用户 / Agent 可以直接编辑 SKILL.md (不通过工具),next loadUserSkills 自动 pickup。
// 详见 docs/roadmap-post-skill-v1.md PR4。

model UserSkill {
  id          String   @id @default(cuid())
  /// V1 only "agent"; V2 will add "workspace" / "global"
  ownerType   String
  /// agentId / workspaceId / null (global preset 用 null，V1 永远是 agentId)
  ownerId     String
  /// User-facing name. Mirrors SKILL.md frontmatter.name; kept in DB for
  /// fast unique check + cheap list query without reading every file.
  name        String
  /// BlobStorage key prefix where this skill's files live. Format:
  /// `agents/<ownerId>/skills/<id>/`. SKILL.md and workflows/*.json
  /// are read relative to this prefix.
  dirPath     String

  // ── 状态 + 使用统计 (DB-only,fs 不存,改动频繁) ──
  enabled       Boolean   @default(true)
  invokedCount  Int       @default(0)
  lastInvokedAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ownerType, ownerId])
  @@index([enabled])
  @@map("user_skills")
}

// ─── 设计稿（SVG 矢量画布） ───

model Design {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  parentId     String?
  order        Int      @default(0)
  figmaUrl     String?
  figmaFileKey String?
  figmaNodeId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tastes    Taste[]

  @@index([workspaceId])
  @@index([parentId])
  @@map("designs")
}

// ─── Taste（设计资源，通过 designId 关联，如 Record 之于 Table） ───

model Taste {
  id              String    @id @default(cuid())
  designId        String
  name            String
  fileName        String
  filePath        String?
  x               Float     @default(0)
  y               Float     @default(0)
  width           Float     @default(200)
  height          Float     @default(200)
  order           Int       @default(0)
  source          String    @default("upload")
  figmaUrl        String?
  // Taste × Chatbot (Phase 1): 设计风格结构化 meta。null 表示未生成；
  // svgHash 作为缓存失效 key，SVG 内容变更后 regenerate 会重算。
  meta            Json?
  metaGeneratedAt DateTime?
  svgHash         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@map("tastes")
}

// ─── Idea（Markdown 文档，与 Table / Design 并列的第三类 Artifact） ───

model Idea {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  parentId    String?
  order       Int      @default(0)
  content     String   @default("")
  version     Int      @default(0)
  // Snapshot of the heading structure extracted from `content` on every
  // save. Persisted as JSON so the @mention picker can surface idea
  // sections without re-parsing every document on each keystroke, and so
  // heading slugs stay stable across search calls.
  // Shape: `Array<{ slug: string; text: string; level: number; order: number }>`
  sections    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attachments IdeaAttachment[]
  blocks      IdeaBlock[]

  @@index([workspaceId])
  @@index([parentId])
  @@map("ideas")
}

// ─── IdeaBlock (PR6, 2026-04-29) ───────────────────────────────────────────
// Idea 内容的"块级"分解。Idea.content 仍是 source of truth (原 Markdown 字符串
// 不动,旧 API 兼容);写时同步派生这张表,FE 在 PR7+ 切到 block-based 渲染时
// 直接读这张表,无需在客户端再 parse Markdown。
//
// 关键约束:
//   - parseToBlocks(content) 必须保留原始字节 —— 把 blocks.map(b=>b.content).join("")
//     拼回去严格等于 content。这样 source 模式 / Markdown 导出 / 第三方 git diff
//     全部稳定。
//   - 一篇 idea 写入时:在 PUT /content 的 $transaction 里
//     deleteMany({ideaId}) + createMany(parsed blocks)。原子。
//   - blockId 永久稳定 (cuid)。后续 PR8+ 的 `<ideaId>#<blockId>` mention 锚点
//     不会因为编辑 / heading 重命名失效 —— PR6 不动 Mention,PR7+ 再迁移。
//
// 详见 docs/roadmap-post-skill-v1.md PR6。
model IdeaBlock {
  id            String   @id @default(cuid())
  ideaId        String
  /// fractional indexing: 0, 1, 2, ... 之间允许 0.5 / 0.25 等插入。Float 让
  /// 拖动重排只改一个 block 的 order 而不必重写整个序列。V1 写入时按整数
  /// 0,1,2...,后续 PR8 拖动重排开始用小数。
  order         Float
  /// "heading" | "paragraph" | "list" | "code" | "quote" | "divider" |
  /// "html" | "table"。enum-like,V1 不限 string 以便 PR10 加新类型。
  type          String
  /// 这个 block 的原始 Markdown 字节(含 trailing newline 等)。reassemble
  /// 把所有 block 的 content 直接 concat = 原 Idea.content。
  content       String   @db.Text
  /// 类型特有元数据:
  ///   heading: { level: 1-6, slug: string }
  ///   list:    { ordered: bool, startsAt?: number }
  ///   code:    { language: string | null }
  ///   table:   { columns: number, hasHeader: bool }
  ///   image:   不在 V1,内嵌图片仍在 paragraph 里,PR10 时单拆
  props         Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId, order])
  @@map("idea_blocks")
}

// ─── IdeaAttachment (PR5, 2026-04-29) ──────────────────────────────────────
// 灵感文档的二进制附件 (图 / SVG / PDF / 视频 / ...)。Markdown 主体只存 URL
// 引用,这里持久化 fs key + 元数据。
//
// 资产文件存 BlobStorage 下:
//   idea-attachments/<workspaceId>/<sha256>.<ext>
//
// 同 workspace 内同 hash 的文件 dedup —— 多个 IdeaAttachment 行可以指向同一个
// blob (同一图片在多个 idea 出现时不重复存储)。删除某个 IdeaAttachment 时
// 检查同 (workspaceId, hash) 还有无其它行,无则物理删除 blob。
//
// 跨 workspace 不 dedup (隐私边界)。
//
// idea 级联删除走 onDelete: Cascade —— Idea 删了所有 IdeaAttachment 行
// 一并消失,blob 由路由层在 Idea 删除事务内手动 reap (refcount 检查后)。

model IdeaAttachment {
  id           String   @id @default(cuid())
  ideaId       String
  workspaceId  String
  /// sha256 hex of file content. Primary dedup key within a workspace.
  hash         String
  /// File extension WITHOUT leading dot, e.g. "png" / "svg" / "pdf".
  /// Lowercased, sanitised (no /, no ..). Used to build the blob key.
  ext          String
  /// MIME from upload validation. We trust this only after server-side
  /// sniffing / extension whitelist; never echo raw client value.
  mime         String
  /// Bytes. Bounded by per-mime upload limits (see ideaAttachmentService).
  size         Int
  /// Original filename for display (FE shows on hover). Sanitised,
  /// max 200 chars. Not used in fs path.
  originalName String   @default("")
  /// User who uploaded — nullable for Agent uploads with no user context.
  uploadedBy   String?
  createdAt    DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([workspaceId, hash])
  @@map("idea_attachments")
}

// ─── Mention（@ 提及的关系记录，源 → 目标 的单向边） ───
// 每次 source 内容保存时 diff 重建该 source 对应的所有 Mention 行。
// targetType=idea-section 时，targetId 使用 "<ideaId>#<slug>" 组合键，便于反向查询。
// 源实体删除：CASCADE（通过路由层在事务内删自身行）。
// 目标实体删除：先用 targetType+targetId 查 incoming refs，UI 弹二次确认，确认后路由层
// 软处理——把孤儿 Mention 行留在表里（sourceId 仍有效，指向新"坏链"），下一次 source 保存
// 时 diff 会把坏链自动清掉；或者管理端批清。不做 DB 级 CASCADE 以避免 Idea→Mention→Idea 环。
model Mention {
  id          String @id @default(cuid())
  workspaceId String

  sourceType String // 目前只有 "idea"；预留 "table-record" 等扩展
  sourceId   String

  targetType String // "view" | "taste" | "idea" | "idea-section"
  targetId   String // idea-section 用 "<ideaId>#<slug>" 组合键

  rawLabel       String // Agent / 用户写进 Markdown 的可视文本（[@label] 里的 label）
  contextExcerpt String? // 前后各 80 字符，给反向面板提供预览

  createdAt DateTime @default(now())

  // 反向查询："某个 target 被谁引用了"——mention 二次确认卡片直接用这个
  @@index([workspaceId, targetType, targetId])
  // 正向清理："某个 source 的所有外链"——diff 重建时 deleteMany where sourceType/sourceId
  @@index([sourceType, sourceId])
  @@map("mentions")
}

// ─── Demo（Vibe design + Vibe coding 的产物，可运行的前端代码 artifact） ───
// - id 使用应用侧生成的格式（见 services/idGenerator.ts），非 cuid
// - 文件内容不进 DB：全部落在 ~/.imagebase/demos/<id>/files|dist|published/
// - capabilities 是 JSON 白名单；per-resource 粒度，发布后前端 SDK 按此动态裁剪
// - publishSlug 一旦生成不复用；unpublish 清空后重发布会拿新 slug
model Demo {
  id          String  @id // 应用侧生成 "dm" + 12 位数字
  workspaceId String
  parentId    String? // 未来支持 sidebar 层级；V1 默认 null
  order       Int     @default(0)

  name     String
  template String @default("static") // "static" | "react-spa"
  version  Int    @default(0) // 源码版本，每次文件写入 ++

  // 数据访问声明 —— 发布时权限的唯一来源
  dataTables   String[] @default([]) // 声明可访问的 tableId 列表
  dataIdeas    String[] @default([]) // 声明可访问的 ideaId 列表（只读）
  capabilities Json     @default("{}") // { resourceId: Capability[] }

  // 构建状态
  lastBuildAt     DateTime?
  lastBuildStatus String? // "idle" | "building" | "success" | "error"
  lastBuildError  String?

  // 发布状态
  publishSlug            String?   @unique
  publishedVersion       Int?
  publishedAt            DateTime?
  // Source `version` 的快照——publish 时拍下当时的 version 号。后续文件
  // 被写入会让 version 继续递增；前端用 (version > sourceVersionAtPublish)
  // 判定"有未发布的变更"，在 Published 按钮上显示绿点 + 展开 Republish。
  sourceVersionAtPublish Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([publishSlug])
  @@map("demos")
}

// ─── KnowledgeEntry（Agent 知识库 — RAG 存储） ───
// embedding 开发期用 Json 数组存储，生产切 pgvector 时改为 vector(1536)

model KnowledgeEntry {
  id         String   @id @default(cuid())
  agentId    String
  title      String
  content    String   // Markdown 正文（已分块）
  sourceUrl  String?  // 来源 URL
  sourceType String   @default("web") // "web" | "chat" | "manual"
  tags       String[] @default([])
  embedding  Json?    // number[] — 开发期 JSON 存储，生产切 pgvector
  chunkIndex Int      @default(0)
  parentId   String?  // 同源分块共享 parentId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([agentId])
  @@index([agentId, createdAt])
  @@map("knowledge_entries")
}
