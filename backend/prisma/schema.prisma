generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 用户（Phase 2 实现，Phase 1 仅 seed 默认用户） ───

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces WorkspaceMember[]
  documents  Document[]

  @@map("users")
}

// ─── 工作空间（Phase 2 实现） ───

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  documents Document[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("editor")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ─── 文档（Phase 2 实现） ───

model Document {
  id          String   @id @default(cuid())
  workspaceId String
  createdById String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])
  tables    Table[]
  folders   Folder[]
  designs   Design[]

  @@index([workspaceId])
  @@map("documents")
}

// ─── 数据表（fields + views 作为 JSONB 存储） ───

model Table {
  id                 String   @id @default(cuid())
  documentId         String
  name               String
  parentId           String?
  order              Int      @default(0)
  fields             Json     @default("[]")
  views              Json     @default("[]")
  autoNumberCounters Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  records  Record[]

  @@index([documentId])
  @@index([parentId])
  @@map("tables")
}

// ─── 记录（独立表，通过 tableId 关联） ───

model Record {
  id         String   @id @default(cuid())
  tableId    String
  cells      Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  modifiedBy String?

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([cells(ops: JsonbPathOps)], type: Gin)
  @@map("records")
}

// ─── 文件夹（树形结构，自引用） ───

model Folder {
  id         String   @id @default(cuid())
  documentId String
  name       String
  parentId   String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderTree")

  @@index([documentId])
  @@index([parentId])
  @@map("folders")
}

// ─── Chat Agent 对话 & 消息（持久化到 Postgres） ───
// 原 conversationStore 使用内存 Map，backend 重启即丢；迁到 Prisma 后跨进程持久。

model Conversation {
  id           String   @id @default(cuid())
  documentId   String
  title        String   @default("新对话")
  summary      String?
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages Message[]

  @@index([documentId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool"
  content        String
  thinking       String?
  toolCalls      Json?
  toolResult     Json?
  timestamp      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("messages")
}

// ─── 设计稿（Figma 链接） ───

model Design {
  id           String   @id @default(cuid())
  documentId   String
  name         String
  parentId     String?
  order        Int      @default(0)
  figmaUrl     String?
  figmaFileKey String?
  figmaNodeId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([parentId])
  @@map("designs")
}
